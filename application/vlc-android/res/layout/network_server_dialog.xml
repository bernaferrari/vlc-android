<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:minWidth="300dp">

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <TextView
                android:id="@+id/server_url"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_below="@+id/server_folder"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:padding="4dp"
                android:singleLine="true"
                android:textColor="?attr/font_default"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="ftp://foo@127.0.0.1:21/path" />

        <View
                android:id="@+id/view2"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="?attr/default_separator"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/server_url" />

        <!-- 
          =====================================================================================
          FIRST REAL INTEROP HOSTING DEMO (Wave 0 / bootstrap) - Pattern #1
          VLCComposeView embedded directly inside legacy XML layout (network_server_dialog.xml).

          This is the "using VLCComposeView inside an existing layout" pattern.

          - The tag is a normal custom view; no dataBinding or special inflation needed.
          - In Kotlin host (see NetworkServerDialog.kt): 
                val composeHost = v.findViewById<VLCComposeView>(R.id.compose_interop_demo)
                composeHost.setContent {
                    VLCTheme {
                        VLCDropdownItem(text = "Compose-powered item (interop demo)")
                    }
                }

          BEFORE (legacy): dropdown_item.xml (simple TextView) inflated by ArrayAdapter for the
                           protocol Spinner items. Still active below - kept for compatibility.
          AFTER (demo): Legacy spinner + ArrayAdapter continue 100% unchanged.
                        + Live Compose rendering of the equivalent VLCDropdownItem appears here
                          in the dialog UI as proof the bridge works end-to-end.

          Hybrid strategy notes (copy-paste for future waves):
          * Leaf Composables (VLCDropdownItem, VLCDebugLogLine, VLCInfoItem, ...) are safe to host
            immediately because they have zero side effects and wrap their own VLCTheme.
          * Two patterns demonstrated:
              1. Layout XML: <org.videolan.vlc.compose.interop.VLCComposeView .../>  (this file)
              2. Pure Kotlin: ComposeView(context).apply { setContent { VLCTheme { ... } } }
          * Original XML layouts (dropdown_item.xml etc.) are preserved during demonstration.
          * Next step example: replace ArrayAdapter usages with custom adapters whose
            getView()/getDropDownView() return recycled ComposeViews for full migration.
          * Rollback: remove the id usage + the view tag; no other changes required.

          See also: application/compose/src/main/java/.../interop/VLCCompose.kt
                    application/compose/src/main/java/.../components/DropdownItem.kt
          =====================================================================================
        -->
        <org.videolan.vlc.compose.interop.VLCComposeView
                android:id="@+id/compose_interop_demo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view2" />

        <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/server_protocol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="16dp"
                android:entries="@array/server_protocols"
                app:layout_constraintBottom_toBottomOf="@+id/server_port"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/server_port" />

        <TextView
                android:id="@+id/server_port_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBaseline="@+id/server_protocol"
                android:layout_alignTop="@+id/server_protocol"
                android:layout_marginEnd="8dp"
                android:text="@string/server_port"
                app:layout_constraintBottom_toBottomOf="@+id/server_port"
                app:layout_constraintEnd_toStartOf="@+id/server_port"
                app:layout_constraintTop_toTopOf="@+id/server_port" />

        <EditText
                android:id="@+id/server_port"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:inputType="number"
                android:minWidth="30dp"
                android:singleLine="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/compose_interop_demo" />

        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/server_domain"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/server_port">

            <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/server_domain_hint"
                    android:inputType="textUri"
                    android:singleLine="true">

                <requestFocus />
            </EditText>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/server_username"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/server_domain">

            <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/server_username_hint"
                    android:inputType="text"
                    android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/server_folder"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/server_username">

            <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/server_folder_hint"
                    android:inputType="textUri"
                    android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/server_name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/server_folder">

            <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/server_servername_hint"
                    android:inputType="text"
                    android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
                android:id="@+id/server_cancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="@string/cancel"
                app:layout_constraintBottom_toBottomOf="@+id/server_save"
                app:layout_constraintEnd_toStartOf="@+id/server_save"
                app:layout_constraintTop_toTopOf="@+id/server_save" />

        <Button
                android:id="@+id/server_save"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp"
                android:text="@string/ok"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/server_name" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<!--
  VLC shared string resources for Compose Multiplatform.
  
  These are available in commonMain via `org.jetbrains.compose.resources.Res`
  and `stringResource(Res.string.xxx)`. They supplement (not replace) the
  Android resource system. Shared composables that need localized text should
  use these instead of Android R.string references.
-->
